Concept: Index Marking

Example

Input: 4 3 2 7 8 2 3 1
Output: [2, 3]

--------------------------------------------------------------------------------

def findDuplicates(nums):
    result = []

    for num in nums:
        index = abs(num) - 1

        if nums[index] < 0:
            result.append(abs(num))
        else:
            nums[index] = -nums[index]

    return result


# ===== MAIN PROGRAM =====
nums = list(map(int, input("Enter numbers: ").split()))

print("Duplicates:", findDuplicates(nums))
