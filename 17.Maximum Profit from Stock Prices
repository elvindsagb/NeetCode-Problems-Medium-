Concept: Greedy Algorithm

Example

Input: 7 1 5 3 6 4
Output: 5

-----------------------------------------------------------------------------------------------

def maxProfit(prices):
    min_price = float('inf')
    max_profit = 0

    for price in prices:
        if price < min_price:
            min_price = price
        else:
            max_profit = max(max_profit, price - min_price)

    return max_profit


# ===== MAIN PROGRAM =====
prices = list(map(int, input("Enter stock prices: ").split()))

print("Maximum profit:", maxProfit(prices))
