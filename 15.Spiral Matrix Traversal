Concept: Matrix Traversal

Example matrix

1 2 3
4 5 6
7 8 9

Output

1 2 3 6 9 8 7 4 5

-------------------------------------------------------------------------------------------------------------------

def spiralOrder(matrix):
    result = []

    while matrix:
        result += matrix.pop(0)

        if matrix and matrix[0]:
            for row in matrix:
                result.append(row.pop())

        if matrix:
            result += matrix.pop()[::-1]

        if matrix and matrix[0]:
            for row in matrix[::-1]:
                result.append(row.pop(0))

    return result


# ===== MAIN PROGRAM =====
rows = int(input("Enter number of rows: "))
