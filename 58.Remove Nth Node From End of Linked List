Concept: Two Pointers

------------------------------------------------------------------------------------------------------------------

class ListNode:
    def __init__(self, val):
        self.val = val
        self.next = None


def removeNthFromEnd(head, n):
    dummy = ListNode(0)
    dummy.next = head
    fast = slow = dummy

    for _ in range(n + 1):
        fast = fast.next

    while fast:
        fast = fast.next
        slow = slow.next

    slow.next = slow.next.next
    return dummy.next


def printList(head):
    while head:
        print(head.val, end=" -> ")
        head = head.next
    print("None")


# ===== MAIN PROGRAM =====
values = list(map(int, input("Enter linked list values: ").split()))
n = int(input("Enter n: "))

head = None
for val in reversed(values):
    node = ListNode(val)
    node.next = head
    head = node

head = removeNthFromEnd(head, n)

print("Updated list:")
printList(head)
