Concept: Dynamic Programming + Hash Set

Example

Input:
s = "leetcode"
wordDict = ["leet","code"]
Output: True

-----------------------------------------------------------------------------------------------------------

def wordBreak(s, wordDict):
    word_set = set(wordDict)
    dp = [False] * (len(s) + 1)
    dp[0] = True

    for i in range(1, len(s) + 1):
        for j in range(i):
            if dp[j] and s[j:i] in word_set:
                dp[i] = True
                break

    return dp[len(s)]


# ===== MAIN PROGRAM =====
s = input("Enter string: ")
wordDict = input("Enter dictionary words: ").split()

print("Can be segmented:", wordBreak(s, wordDict))
