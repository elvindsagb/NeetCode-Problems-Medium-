Concept: Dynamic Programming (Matrix)

------------------------------------------------------------------------------------------------------

def minFallingPathSum(matrix):
    n = len(matrix)

    for i in range(1, n):
        for j in range(n):
            best = matrix[i-1][j]
            if j > 0:
                best = min(best, matrix[i-1][j-1])
            if j < n-1:
                best = min(best, matrix[i-1][j+1])

            matrix[i][j] += best

    return min(matrix[-1])


# ===== MAIN PROGRAM =====
n = int(input("Enter n: "))
matrix = []

print("Enter matrix:")
for _ in range(n):
    matrix.append(list(map(int, input().split())))

print("Minimum falling path sum:", minFallingPathSum(matrix))
