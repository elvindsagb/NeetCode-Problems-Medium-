Concept: Modified Binary Search

Example

Input: 4 5 6 7 0 1 2
Target: 0
Output: 4

-----------------------------------------------------------------------------------------------

def searchRotated(nums, target):
    left, right = 0, len(nums) - 1

    while left <= right:
        mid = (left + right) // 2

        if nums[mid] == target:
            return mid

        # Left half is sorted
        if nums[left] <= nums[mid]:
            if nums[left] <= target < nums[mid]:
                right = mid - 1
            else:
                left = mid + 1
        else:
            # Right half is sorted
            if nums[mid] < target <= nums[right]:
                left = mid + 1
            else:
                right = mid - 1

    return -1


# ===== MAIN PROGRAM =====
nums = list(map(int, input("Enter rotated sorted array: ").split()))
target = int(input("Enter target: "))

print("Index:", searchRotated(nums, target))
