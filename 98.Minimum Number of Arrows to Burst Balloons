Concept: Greedy + Intervals

-------------------------------------------------------------------------------------------------------------

def findMinArrowShots(points):
    if not points:
        return 0

    points.sort(key=lambda x: x[1])
    arrows = 1
    end = points[0][1]

    for start, finish in points:
        if start > end:
            arrows += 1
            end = finish

    return arrows


# ===== MAIN PROGRAM =====
n = int(input("Enter number of balloons: "))
points = []

print("Enter intervals:")
for _ in range(n):
    points.append(list(map(int, input().split())))

print("Minimum arrows:", findMinArrowShots(points))
