Concept: BFS + Queue

---------------------------------------------------------------------------------------------

class TreeNode:
    def __init__(self, val):
        self.val = val
        self.left = None
        self.right = None


from collections import deque

def zigzagLevelOrder(root):
    if not root:
        return []

    result = []
    queue = deque([root])
    left_to_right = True

    while queue:
        level = []
        for _ in range(len(queue)):
            node = queue.popleft()
            level.append(node.val)

            if node.left:
                queue.append(node.left)
            if node.right:
                queue.append(node.right)

        if not left_to_right:
            level.reverse()

        result.append(level)
        left_to_right = not left_to_right

    return result


# ===== MAIN PROGRAM =====
# Example Tree
root = TreeNode(1)
root.left = TreeNode(2)
root.right = TreeNode(3)

print("Zigzag traversal:", zigzagLevelOrder(root))
