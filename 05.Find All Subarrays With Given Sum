Concept: Prefix Sum + Hash Map

Example

Input:
Array: 1 2 3 2 5
Target: 5

Output:
Subarrays [2,3] and [5]

--------------------------------------------------------------------------------------------------------------------------------------

def subarraySum(nums, target):
    prefix = {0: 1}
    current_sum = 0
    count = 0

    for num in nums:
        current_sum += num

        if current_sum - target in prefix:
            count += prefix[current_sum - target]

        prefix[current_sum] = prefix.get(current_sum, 0) + 1

    return count


# ===== MAIN PROGRAM =====
nums = list(map(int, input("Enter numbers: ").split()))
target = int(input("Enter target sum: "))

print("Number of subarrays:", subarraySum(nums, target))
