Concept: Dynamic Programming

Example

Input: 10 9 2 5 3 7 101 18
Output: 4

---------------------------------------------------------------------------------------------------------------------------

def lengthOfLIS(nums):
    dp = [1] * len(nums)

    for i in range(len(nums)):
        for j in range(i):
            if nums[i] > nums[j]:
                dp[i] = max(dp[i], dp[j] + 1)

    return max(dp)


# ===== MAIN PROGRAM =====
nums = list(map(int, input("Enter numbers: ").split()))

print("Length of LIS:", lengthOfLIS(nums))
