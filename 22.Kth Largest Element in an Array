Concept: Heap / Sorting

Example

Input: 3 2 1 5 6 4
k = 2
Output: 5

-----------------------------------------------------------------------------------------------

def kthLargest(nums, k):
    nums.sort(reverse=True)
    return nums[k - 1]


# ===== MAIN PROGRAM =====
nums = list(map(int, input("Enter numbers: ").split()))
k = int(input("Enter k: "))

print("Kth largest element:", kthLargest(nums, k))
