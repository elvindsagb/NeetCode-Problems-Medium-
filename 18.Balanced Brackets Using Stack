Concept: Stack

Example

Input: {[()()]}
Output: Balanced


------------------------------------------------------------------------------------

def isBalanced(s):
    stack = []
    pairs = {')': '(', '}': '{', ']': '['}

    for char in s:
        if char in "({[":
            stack.append(char)
        else:
            if not stack or stack.pop() != pairs[char]:
                return False

    return True


# ===== MAIN PROGRAM =====
text = input("Enter brackets string: ")

if isBalanced(text):
    print("Balanced brackets")
else:
    print("Not balanced")
