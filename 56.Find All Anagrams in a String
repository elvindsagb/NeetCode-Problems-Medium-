Concept: Sliding Window + Frequency Count

Example

Input:
s = "cbaebabacd"
p = "abc"
Output: [0, 6]

---------------------------------------------------------------------------------------------


def findAnagrams(s, p):
    from collections import Counter

    p_count = Counter(p)
    window = Counter()
    result = []
    k = len(p)

    for i in range(len(s)):
        window[s[i]] += 1

        if i >= k:
            if window[s[i-k]] == 1:
                del window[s[i-k]]
            else:
                window[s[i-k]] -= 1

        if window == p_count:
            result.append(i - k + 1)

    return result


# ===== MAIN PROGRAM =====
s = input("Enter main string: ")
p = input("Enter pattern: ")

print("Anagram indices:", findAnagrams(s, p))
