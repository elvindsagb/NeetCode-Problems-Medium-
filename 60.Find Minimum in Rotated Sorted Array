Concept: Binary Search

Example

Input: 3 4 5 1 2
Output: 1

----------------------------------------------------------------------------------------------

def findMin(nums):
    left, right = 0, len(nums) - 1

    while left < right:
        mid = (left + right) // 2

        if nums[mid] > nums[right]:
            left = mid + 1
        else:
            right = mid

    return nums[left]


# ===== MAIN PROGRAM =====
nums = list(map(int, input("Enter rotated array: ").split()))

print("Minimum element:", findMin(nums))
