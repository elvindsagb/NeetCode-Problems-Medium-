Concept: Stack

Example

Input: 2 1 + 3 * → Output: 9

--------------------------------------------------------------------------------------------------------

def evalRPN(tokens):
    stack = []

    for token in tokens:
        if token in "+-*/":
            b = stack.pop()
            a = stack.pop()

            if token == "+":
                stack.append(a + b)
            elif token == "-":
                stack.append(a - b)
            elif token == "*":
                stack.append(a * b)
            else:
                stack.append(int(a / b))
        else:
            stack.append(int(token))

    return stack[0]


# ===== MAIN PROGRAM =====
tokens = input("Enter tokens: ").split()
print("Result:", evalRPN(tokens))
