Concept: Two Pointers

Example

Input: 1 8 6 2 5 4 8 3 7
Output: 49

-----------------------------------------------------------------------------------------------------------------------

def maxArea(height):
    left = 0
    right = len(height) - 1
    max_area = 0

    while left < right:
        width = right - left
        area = min(height[left], height[right]) * width
        max_area = max(max_area, area)

        if height[left] < height[right]:
            left += 1
        else:
            right -= 1

    return max_area


# ===== MAIN PROGRAM =====
heights = list(map(int, input("Enter heights: ").split()))

print("Maximum water container area:", maxArea(heights))
