Concept: Backtracking

Example

Input: 1 2 3
Output: All subsets

-------------------------------------------------------------------------------------------------------------------

def subsets(nums):
    result = []

    def backtrack(start, path):
        result.append(path[:])

        for i in range(start, len(nums)):
            path.append(nums[i])
            backtrack(i + 1, path)
            path.pop()

    backtrack(0, [])
    return result


# ===== MAIN PROGRAM =====
nums = list(map(int, input("Enter numbers: ").split()))

print("Subsets:", subsets(nums))
