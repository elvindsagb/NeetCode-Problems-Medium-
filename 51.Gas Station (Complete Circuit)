Concept: Greedy

Example

Input:
gas = 1 2 3 4 5
cost = 3 4 5 1 2
Output: 3

----------------------------------------------------------------------------------------------------------------

def canCompleteCircuit(gas, cost):
    total = 0
    current = 0
    start = 0

    for i in range(len(gas)):
        total += gas[i] - cost[i]
        current += gas[i] - cost[i]

        if current < 0:
            start = i + 1
            current = 0

    return start if total >= 0 else -1


# ===== MAIN PROGRAM =====
gas = list(map(int, input("Enter gas values: ").split()))
cost = list(map(int, input("Enter cost values: ").split()))

print("Start index:", canCompleteCircuit(gas, cost))
