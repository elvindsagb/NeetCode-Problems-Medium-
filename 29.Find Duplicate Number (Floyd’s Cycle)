Concept: Fast & Slow Pointer

Example

Input: 1 3 4 2 2
Output: 2

--------------------------------------------------------------------------------------------------------

def findDuplicate(nums):
    slow = nums[0]
    fast = nums[0]

    while True:
        slow = nums[slow]
        fast = nums[nums[fast]]

        if slow == fast:
            break

    slow = nums[0]
    while slow != fast:
        slow = nums[slow]
        fast = nums[fast]

    return slow


# ===== MAIN PROGRAM =====
nums = list(map(int, input("Enter numbers: ").split()))

print("Duplicate number:", findDuplicate(nums))
