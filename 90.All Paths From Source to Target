Concept: Graph + DFS

Example

Input: [[1,2],[3],[3],[]]
Output: [[0,1,3],[0,2,3]]

-----------------------------------------------------------------------------------------------------------------------

def allPathsSourceTarget(graph):
    result = []

    def dfs(node, path):
        if node == len(graph) - 1:
            result.append(path[:])
            return

        for neighbor in graph[node]:
            path.append(neighbor)
            dfs(neighbor, path)
            path.pop()

    dfs(0, [0])
    return result


# ===== MAIN PROGRAM =====
n = int(input("Enter number of nodes: "))
graph = []

print("Enter adjacency list:")
for _ in range(n):
    graph.append(list(map(int, input().split())))

print("All paths:", allPathsSourceTarget(graph))
