Concept: Matrix (Transpose + Reverse)

Example

Input:

1 2 3
4 5 6
7 8 9

Output:

7 4 1
8 5 2
9 6 3

-------------------------------------------------------------------------------------------------------------

def rotate(matrix):
    n = len(matrix)

    # Transpose
    for i in range(n):
        for j in range(i, n):
            matrix[i][j], matrix[j][i] = matrix[j][i], matrix[i][j]

    # Reverse each row
    for row in matrix:
        row.reverse()

    return matrix


# ===== MAIN PROGRAM =====
n = int(input("Enter n: "))
matrix = []

print("Enter matrix:")
for _ in range(n):
    matrix.append(list(map(int, input().split())))

result = rotate(matrix)

print("Rotated matrix:")
for row in result:
    print(row)




