Concept: Three Pointer

Example

Input: 2 0 2 1 1 0
Output: 0 0 1 1 2 2

----------------------------------------------------------------------------------------------------------------------------------

def sortColors(nums):
    low = mid = 0
    high = len(nums) - 1

    while mid <= high:
        if nums[mid] == 0:
            nums[low], nums[mid] = nums[mid], nums[low]
            low += 1
            mid += 1
        elif nums[mid] == 1:
            mid += 1
        else:
            nums[mid], nums[high] = nums[high], nums[mid]
            high -= 1

    return nums


# ===== MAIN PROGRAM =====
nums = list(map(int, input("Enter 0s,1s,2s: ").split()))

print("Sorted array:", sortColors(nums))
