Concept: Prefix & Suffix Products

Example

Input: 1 2 3 4
Output: 24 12 8 6

--------------------------------------------------------------------------------------------------------------

def productExceptSelf(nums):
    n = len(nums)
    result = [1] * n

    prefix = 1
    for i in range(n):
        result[i] = prefix
        prefix *= nums[i]

    suffix = 1
    for i in range(n - 1, -1, -1):
        result[i] *= suffix
        suffix *= nums[i]

    return result


# ===== MAIN PROGRAM =====
nums = list(map(int, input("Enter numbers: ").split()))

print("Product array:", productExceptSelf(nums))
